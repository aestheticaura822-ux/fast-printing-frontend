# Assets - Uncomment these lines if you want to IGNORE assets from git
# src/assets/*.jpg
# src/assets/*.png
# src/assets/*.jpeg
# src/assets/*.webp
# src/assets/*.gif
# src/assets/*.svg

# OR if you want to ignore ALL assets folder completely:
